<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/adminBackground"
    android:fillViewport="true"
    tools:context=".orders.OrderPaymentDetailActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvDetailTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Transaction"
                android:textColor="@color/black"
                android:textSize="24sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnOrderDetailRefresh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/black"
                android:text="Refresh"
                android:textColor="@color/white" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvOrderDetailState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Loading transaction detail..."
            android:textColor="@color/adminTextSecondary"
            android:textSize="14sp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_admin_menu_item"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Payment Details"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDetailTransactionId"
                style="@style/OrderDetailLine"
                android:text="Transaction ID: -" />

            <TextView
                android:id="@+id/tvDetailAmount"
                style="@style/OrderDetailLine"
                android:text="Amount: -" />

            <TextView
                android:id="@+id/tvDetailCapturedAmount"
                style="@style/OrderDetailLine"
                android:text="Captured Amount: -" />

            <TextView
                android:id="@+id/tvDetailStatus"
                style="@style/OrderDetailLine"
                android:text="Payment Status: -" />

            <TextView
                android:id="@+id/tvDetailMethod"
                style="@style/OrderDetailLine"
                android:text="Payment Method: -" />

            <TextView
                android:id="@+id/tvDetailProvider"
                style="@style/OrderDetailLine"
                android:text="Provider: -" />

            <TextView
                android:id="@+id/tvDetailProviderTransactionId"
                style="@style/OrderDetailLine"
                android:text="Provider Transaction ID: -" />

            <TextView
                android:id="@+id/tvDetailIdempotencyKey"
                style="@style/OrderDetailLine"
                android:text="Idempotency Key: -" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_admin_menu_item"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Order"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDetailOrderId"
                style="@style/OrderDetailLine"
                android:text="Order ID: -" />

            <TextView
                android:id="@+id/tvDetailOrderNumber"
                style="@style/OrderDetailLine"
                android:text="Order Number: -" />

            <TextView
                android:id="@+id/tvDetailCreatedAt"
                style="@style/OrderDetailLine"
                android:text="Created At: -" />

            <TextView
                android:id="@+id/tvDetailUpdatedAt"
                style="@style/OrderDetailLine"
                android:text="Updated At: -" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_admin_menu_item"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Customer"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDetailCustomerName"
                style="@style/OrderDetailLine"
                android:text="Customer: -" />

            <TextView
                android:id="@+id/tvDetailCustomerEmail"
                style="@style/OrderDetailLine"
                android:text="Email: -" />

            <TextView
                android:id="@+id/tvDetailCustomerId"
                style="@style/OrderDetailLine"
                android:text="Customer ID: -" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDetailError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_admin_menu_item"
            android:padding="14dp"
            android:text="Error: -"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvRelatedTransactions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_admin_menu_item"
            android:padding="14dp"
            android:text="Related Transactions: -"
            android:textColor="@color/black"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvDetailRawResponse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_admin_menu_item"
            android:padding="14dp"
            android:text="Raw Response: -"
            android:textColor="@color/adminTextSecondary"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
