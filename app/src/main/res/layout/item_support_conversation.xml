<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_admin_menu_item"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvSupportSubject"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Order #12345"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSupportUnread"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unread: 2"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvSupportCustomer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Customer: jane@example.com"
        android:textColor="@color/adminTextSecondary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvSupportStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Status: WAITING_STAFF"
        android:textColor="@color/adminTextSecondary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvSupportLastMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:maxLines="2"
        android:text="Last: Any update?"
        android:textColor="@color/adminTextSecondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvSupportTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Feb 10, 2025 08:15"
        android:textColor="@color/adminTextSecondary"
        android:textSize="13sp" />
</LinearLayout>
