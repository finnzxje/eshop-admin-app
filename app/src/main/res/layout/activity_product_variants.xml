<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/adminBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvVariantsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Variant and Stock Management"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvVariantsStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            android:textColor="@color/adminTextSecondary"
            android:textSize="14sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnBackToProductForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Back to Product" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Create Variant"
            android:textColor="@color/black"
            android:textSize="17sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spVariantColor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/edtVariantSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Size, e.g. S, M, L"
            android:inputType="text"
            android:singleLine="true"
            android:textColor="@color/black"
            android:textColorHint="@color/adminTextSecondary" />

        <EditText
            android:id="@+id/edtVariantSku"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="SKU"
            android:inputType="text"
            android:singleLine="true"
            android:textColor="@color/black"
            android:textColorHint="@color/adminTextSecondary" />

        <EditText
            android:id="@+id/edtVariantPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Price"
            android:inputType="numberDecimal"
            android:singleLine="true"
            android:textColor="@color/black"
            android:textColorHint="@color/adminTextSecondary" />

        <EditText
            android:id="@+id/edtVariantQuantity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Initial quantity"
            android:inputType="number"
            android:singleLine="true"
            android:textColor="@color/black"
            android:textColorHint="@color/adminTextSecondary" />

        <CheckBox
            android:id="@+id/chkVariantActive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:checked="true"
            android:text="Active"
            android:textColor="@color/black" />

        <Button
            android:id="@+id/btnCreateVariant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/black"
            android:text="Create Variant"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/tvSelectedVariant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Tap a variant to manage status and stock."
            android:textColor="@color/adminTextSecondary"
            android:textSize="14sp" />

        <ListView
            android:id="@+id/lvProductVariants"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginTop="10dp"
            android:divider="@color/adminDivider"
            android:dividerHeight="1dp" />

        <Button
            android:id="@+id/btnToggleVariantStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/black"
            android:text="Toggle Variant Status"
            android:textColor="@color/white" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Stock Adjustment"
            android:textColor="@color/black"
            android:textSize="17sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edtStockNewQuantity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="New quantity"
            android:inputType="number"
            android:singleLine="true"
            android:textColor="@color/black"
            android:textColorHint="@color/adminTextSecondary" />

        <EditText
            android:id="@+id/edtStockReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Reason, e.g. Manual cycle count"
            android:inputType="text"
            android:singleLine="true"
            android:textColor="@color/black"
            android:textColorHint="@color/adminTextSecondary" />

        <EditText
            android:id="@+id/edtStockNotes"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginTop="8dp"
            android:gravity="top"
            android:hint="Notes"
            android:inputType="textMultiLine"
            android:textColor="@color/black"
            android:textColorHint="@color/adminTextSecondary" />

        <Button
            android:id="@+id/btnAdjustStock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="@color/black"
            android:text="Adjust Stock"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/tvStockAdjustments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Stock adjustment history appears after selecting a variant."
            android:textColor="@color/adminTextSecondary"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
