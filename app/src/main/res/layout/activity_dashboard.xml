<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/adminBackground"
    android:orientation="vertical"
    android:padding="20dp"
    tools:context=".dashboard.DashboardActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvDashboardTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Dashboard"
            android:textColor="@color/black"
            android:textSize="26sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnDashboardRefresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/black"
            android:text="Refresh"
            android:textColor="@color/white" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvDashboardPeriod"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Last 30 days"
        android:textColor="@color/adminTextSecondary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvDashboardState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Loading dashboard..."
        android:textColor="@color/adminTextSecondary"
        android:textSize="14sp"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    style="@style/DashboardCard"
                    android:layout_width="0dp"
                    android:layout_weight="1">

                    <TextView
                        style="@style/DashboardCardLabel"
                        android:text="Total Revenue" />

                    <TextView
                        android:id="@+id/tvRevenueValue"
                        style="@style/DashboardCardValue"
                        android:text="$0.00" />
                </LinearLayout>

                <LinearLayout
                    style="@style/DashboardCard"
                    android:layout_width="0dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1">

                    <TextView
                        style="@style/DashboardCardLabel"
                        android:text="Orders" />

                    <TextView
                        android:id="@+id/tvOrdersValue"
                        style="@style/DashboardCardValue"
                        android:text="0" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <LinearLayout
                    style="@style/DashboardCard"
                    android:layout_width="0dp"
                    android:layout_weight="1">

                    <TextView
                        style="@style/DashboardCardLabel"
                        android:text="Payments" />

                    <TextView
                        android:id="@+id/tvPaymentsValue"
                        style="@style/DashboardCardValue"
                        android:text="$0.00" />
                </LinearLayout>

                <LinearLayout
                    style="@style/DashboardCard"
                    android:layout_width="0dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1">

                    <TextView
                        style="@style/DashboardCardLabel"
                        android:text="New Customers" />

                    <TextView
                        android:id="@+id/tvCustomersValue"
                        style="@style/DashboardCardValue"
                        android:text="0" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <LinearLayout
                    style="@style/DashboardCard"
                    android:layout_width="0dp"
                    android:layout_weight="1">

                    <TextView
                        style="@style/DashboardCardLabel"
                        android:text="Avg Order" />

                    <TextView
                        android:id="@+id/tvAverageOrderValue"
                        style="@style/DashboardCardValue"
                        android:text="$0.00" />
                </LinearLayout>

                <LinearLayout
                    style="@style/DashboardCard"
                    android:layout_width="0dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1">

                    <TextView
                        style="@style/DashboardCardLabel"
                        android:text="Conversion" />

                    <TextView
                        android:id="@+id/tvConversionRate"
                        style="@style/DashboardCardValue"
                        android:text="0.00%" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/tvRevenueTrendTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Revenue Trend"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvRevenueEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="No revenue trend data for the last 30 days."
        android:textColor="@color/adminTextSecondary"
        android:textSize="14sp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/lvRevenueTrend"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        tools:ignore="AdapterViewChildren" />
</LinearLayout>
